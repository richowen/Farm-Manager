# Copy to .env and fill in. All values are REQUIRED unless marked optional.

# Postgres (docker-compose uses these to build DATABASE_URL below)
DB_PASSWORD=changeme-db-password

# The single login password for the app. Pick something long.
APP_PASSWORD=changeme-app-password

# 32+ byte random secret for signing session cookies.
# Generate: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32

# Public origin used for CSRF checks and secure-cookie flag (optional but
# strongly recommended when reverse-proxied over HTTPS, e.g. via SWAG,
# Nginx Proxy Manager, or Cloudflare Tunnel).
# Example: https://farm.example.com
ORIGIN=

# Displayed in the UI header. Optional.
PUBLIC_APP_NAME=Farm Manager

# Built by docker-compose from DB_PASSWORD; override only if you run Postgres
# outside compose.
# DATABASE_URL=postgres://farm:${DB_PASSWORD}@db:5432/farm

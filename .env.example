# Copy to .env and fill in. All values are REQUIRED unless marked optional.

# Postgres (docker-compose uses these to build DATABASE_URL below)
DB_PASSWORD=changeme-db-password

# The single login password for the app. Pick something long.
APP_PASSWORD=changeme-app-password

# 32+ byte random secret for signing session cookies.
# Generate: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32

# Public origin used for CSRF checks, secure-cookie flag, and absolute URLs
# emitted in the iCal feed. Required by SvelteKit's adapter-node — cannot be
# blank. Examples:
#   Local LAN:        http://192.168.1.81:3000
#   HTTPS (proxied):  https://farm.example.com
ORIGIN=

# When fronted by a reverse proxy that terminates TLS (Nginx / Caddy / Traefik
# / SWAG / NPM / Cloudflare Tunnel), forward these headers and set these to
# match. Leave blank for direct-to-container access over plain HTTP.
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host

# Displayed in the UI header. Optional.
PUBLIC_APP_NAME=Farm Manager

# Photo uploads — max size per file in megabytes (default 10). Photos are
# stored under /data/uploads inside the container (bind-mounted to a host path).
# Long edge >2000 px is auto-downscaled.
UPLOAD_MAX_MB=10

# Built by docker-compose from DB_PASSWORD; override only if you run Postgres
# outside compose.
# DATABASE_URL=postgres://farm:${DB_PASSWORD}@db:5432/farm
